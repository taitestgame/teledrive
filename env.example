# TeleCloud Configuration Example
# Copy this file to .env and fill in your values

# Optional: 32-byte master key used to encrypt Telegram session blobs and
# sensitive settings (api_id, api_hash, log_group_id, bot_tokens) at rest.
# If left blank, a secure 32-byte key is automatically generated and saved
# to a persistent 'master.key' file inside your database directory.
# You can also manually generate one with:  openssl rand -hex 32
# WARNING: Losing this key (or the auto-generated 'master.key' file) means
# losing access to your encrypted data. Please back it up separately.
TELECLOUD_MASTER_KEY=

# Optional: HTTP listen address. Defaults to 127.0.0.1 until initial setup
# completes (to prevent first-come-first-serve admin takeover), then 0.0.0.0
# unless overridden here. Set to 127.0.0.1 to keep loopback-only behind a
# reverse proxy/tunnel.
#LISTEN_ADDR=127.0.0.1

# Server port
#PORT=8091

# Number of concurrent upload threads (Default: 2)
# Decrease to 1 for more stable uploads on weak networks, increase to 4 for maximum speed.
#TG_UPLOAD_THREADS=2

# Note: Bot Tokens (Bot Pool) are configured dynamically inside the Admin Settings
# dashboard in the Web UI, and are encrypted at rest in the database.
# The legacy BOT_TOKENS environment variable is no longer supported or used.

# Database configuration
# Default uses SQLite with DATABASE_PATH.
#DATABASE_DRIVER=sqlite
#DATABASE_PATH=database.db
#
# To use MySQL, create a UTF-8 database first, then set:
#DATABASE_DRIVER=mysql
#DATABASE_DSN=telecloud_user:telecloud_password@tcp(127.0.0.1:3306)/telecloud?parseTime=true&charset=utf8mb4
#
# To use PostgreSQL, create a database first, then set:
#DATABASE_DRIVER=postgres
#DATABASE_DSN=postgres://telecloud_user:telecloud_password@127.0.0.1:5432/telecloud?sslmode=disable

# File storage paths
#THUMBS_DIR=static/thumbs
#TEMP_DIR=./temp
#PROXY_URL= # e.g. socks5://127.0.0.1:1080 or http://127.0.0.1:8080

# FFmpeg path for thumbnail generation. 
# Set to "disabled" to skip video/audio thumbnails if FFmpeg is not installed or causing crashes.
#FFMPEG_PATH=ffmpeg

# yt-dlp path for URL media downloads.
# Set to "disabled" to skip yt-dlp functionality if yt-dlp is not installed.
#YTDLP_PATH=yt-dlp

# Torrent support via aria2c (magnet links and .torrent URLs).
# Set to the path of the aria2c executable to enable.
# Included in Docker as /usr/bin/aria2c. Set to "disabled" to skip.
#TORRENT_PATH=aria2c

# Comma-separated list of origins allowed to access the S3 API via CORS
# If left blank or set to *, all origins are allowed.
#S3_CORS_ALLOWED_ORIGINS=*

# Note on Themes: The application supports multiple UI themes (Neon, Cyberpunk, Lavender, Forest)
# and a System theme mode. These are configured directly in the Web UI Settings,
# and do not require any environment variables.
